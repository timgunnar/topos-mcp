  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "node -e \"const{copyFileSync}=require('fs');['LICENSE','README.md','CHANGELOG.md'].forEach(f=>{try{copyFileSync('../../'+f,f)}catch(e){console.error('Missing root file: '+f)}})\""
  },
