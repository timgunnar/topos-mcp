{
  "name": "@timgunnar/topos-mcp",
  "version": "0.2.4",
  "description": "Project intelligence tracker for AI Agent-driven development — 3D topology Dashboard for visualizing project status",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timgunnar/topos-mcp.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "README_ZH.md",
    "CHANGELOG.md",
    "CHANGELOG_ZH.md"
  ],
  "bin": {
    "topos": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "node -e \"const{copyFileSync}=require('fs');['LICENSE','README.md','README_ZH.md','CHANGELOG.md','CHANGELOG_ZH.md'].forEach(f=>{try{copyFileSync('../../'+f,f)}catch(e){console.error('Missing root file: '+f)}})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yaml": "^2.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  }
}
